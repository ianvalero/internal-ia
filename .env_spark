############################
#         Proxy            #
############################
HTTP_PROXY=http://14.10.73.85:8080
HTTPS_PROXY=http://14.10.73.85:8080
NO_PROXY=vllm,vllm-embedding,librechat,qdrant,mongodb,langfuse-web,langfuse-worker,langfuse-postgres,langfuse-clickhouse,langfuse-redis,langfuse-minio,localhost,127.0.0.1

############################
#        Huggingface       #
############################
HF_HUB_OFFLINE=1
HF_TRANSFORMERS_OFFLINE=1
HF_DATASETS_OFFLINE=1

############################
#          vLLM            #
############################
VLLM_HOST=0.0.0.0
VLLM_PORT=8000
VLLM_BASE_URL="http://vllm:${VLLM_PORT}"
VLLM_DTYPE=bfloat16
VLLM_MAX_MODEL_LEN=32768
VLLM_GPU_MEMORY_UTIL=0.83
VLLM_MAX_NUM_SEQS=64
VLLM_MODEL_PATH=/models/Qwen2.5-14B-Instruct

# Optimizaciones ARM64/GB10
VLLM_OMP_NUM_THREADS=20
VLLM_WORKER_MULTIPROC_METHOD=spawn
VLLM_TOKENIZERS_PARALLELISM=true

CUDA_VISIBLE_DEVICES=0
NVIDIA_VISIBLE_DEVICES=all
NVIDIA_DRIVER_CAPABILITIES=all

############################
#      vLLM Embedding      #
############################
EMBEDDING_HOST=0.0.0.0
EMBEDDING_PORT=8001
EMBEDDING_BASE_URL="http://vllm:${EMBEDDING_PORT}"
EMBEDDING_MODEL_PATH=/models/Qwen3-Embedding-8B
EMBEDDING_DTYPE=bfloat16
EMBEDDING_MAX_MODEL_LEN=8192
EMBEDDING_GPU_MEMORY_UTIL=0.15
EMBEDDING_OMP_NUM_THREADS=4