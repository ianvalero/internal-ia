############################
#         Proxy            #
############################
HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=vllm,librechat,qdrant,mongodb,localhost,127.0.0.1

############################
#          vLLM            #
############################
VLLM_HOST=0.0.0.0
VLLM_PORT=8000
VLLM_BASE_URL=http://vllm:8000
CUDA_VISIBLE_DEVICES=0
NVIDIA_VISIBLE_DEVICES=all
NVIDIA_DRIVER_CAPABILITIES=all
MODEL_PATH=/models/Qwen2.5-14B-Instruct
MAX_MODEL_LEN=16384
GPU_MEMORY_UTIL=0.90
ATTENTION_BACKEND=FLASHINFER
MAX_NUM_SEQS=64

# Offline mode
HF_HUB_OFFLINE=1
TRANSFORMERS_OFFLINE=1
HF_DATASETS_OFFLINE=1

# Optimizaciones ARM64/GB10
OMP_NUM_THREADS=20
VLLM_WORKER_MULTIPROC_METHOD=spawn
TOKENIZERS_PARALLELISM=true

############################
#        LibreChat         #
############################
LIBRECHAT_HOST=0.0.0.0
LIBRECHAT_PORT=3080

# Database
MONGO_URI=mongodb://mongodb:27017/LibreChat
MONGO_INITDB_DATABASE=librechat

# Auth
JWT_SECRET=supersecretkey
JWT_REFRESH_SECRET=supersecretrefresh
ALLOW_EMAIL_LOGIN="true"
ALLOW_REGISTRATION="true"

NODE_OPTIONS="--max-old-space-size=4096"

# RAG
RAG_API_URL=http://cerebro:9000
EMBEDDINGS_PROVIDER=huggingface
EMBEDDINGS_MODEL=sentence-transformers/all-MiniLM-L6-v2
HF_TOKEN=hf_xxxx

############################
#          Qdrant          #
############################
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT__SERVICE__GRPC_PORT=6334
QDRANT__STORAGE__PERFORMANCE__MAX_SEARCH_THREADS=8
QDRANT__STORAGE__OPTIMIZERS__MEMMAP_THRESHOLD_KB=20000

############################
#         Cerebro          #
############################
CEREBRO_HF_HUB_OFFLINE=1
CEREBRO_TRANSFORMERS_OFFLINE=1
CEREBRO_HF_DATASETS_OFFLINE=1
CEREBRO_OMP_NUM_THREADS=16